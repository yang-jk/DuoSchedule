/* Content Area */

width: 101px;
height: 22px;

/* Body/Regular */
font-family: 'SF Pro';
font-style: normal;
font-weight: 400;
font-size: 17px;
line-height: 22px;
/* identical to box height, or 129% */
text-align: center;

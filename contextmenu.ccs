/* Context Menu */

box-sizing: border-box;

position: relative;
width: 2110px;
height: 980px;

background: #F5F5F5;
border: 1px dashed #6155F5;
border-radius: 5px;


/* Alignment=Horizontal (iPad only), Side=Trailing */

position: absolute;
width: 351px;
height: 160px;
left: 1470px;
top: 20px;



/* Content Area */

/* Auto layout */
display: flex;
flex-direction: column;
justify-content: center;
align-items: center;
padding: 165px 125px;
gap: 10px;


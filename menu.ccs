/* Menu - iPad - Actions */

box-sizing: border-box;

position: relative;
width: 542px;
height: 581px;
left: 1740px;
top: 100px;

background: #F5F5F5;
border: 1px dashed #6155F5;
border-radius: 5px;


/* Mode=Dark */

/* Auto layout */
display: flex;
flex-direction: column;
align-items: center;
padding: 10px 8px;
isolation: isolate;

position: absolute;
width: 238px;
height: 541px;
left: 284px;
top: 20px;



/* Liquid Glass - Regular - Medium */

position: absolute;
left: 0px;
right: 0px;
top: 0px;
bottom: 0px;


/* Inside auto layout */
flex: none;
order: 0;
flex-grow: 0;
z-index: 0;


/* Fill + Shadow */

position: absolute;
left: 0px;
right: 0px;
top: 0px;
bottom: 0px;

background: linear-gradient(0deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.06)), linear-gradient(0deg, rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), #CCCCCC;
background-blend-mode: normal, normal, color-burn;
opacity: 0.67;
box-shadow: 0px 8px 40px rgba(0, 0, 0, 0.12);
border-radius: 32px;


/* Glass Effect */

position: absolute;
left: 0px;
right: 0px;
top: 0px;
bottom: 0px;

background: rgba(0, 0, 0, 0.004);
border-radius: 32px;


/* Menu Item */

/* Auto layout */
display: flex;
flex-direction: row;
align-items: center;
padding: 0px 8px 0px 6px;
gap: 6px;

width: 222px;
height: 40px;


/* Inside auto layout */
flex: none;
order: 1;
align-self: stretch;
flex-grow: 0;
z-index: 1;


/* Leading */

/* Auto layout */

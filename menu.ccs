width: 14px;
height: 20px;

font-family: 'SF Pro';
font-style: normal;
font-weight: 510;
font-size: 15px;
line-height: 20px;
/* identical to box height, or 133% */
display: flex;
align-items: center;
text-align: center;
font-feature-settings: 'ss15' on;

color: #727272;

mix-blend-mode: plus-darker;

/* Inside auto layout */
flex: none;
order: 1;
flex-grow: 0;



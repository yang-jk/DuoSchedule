<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="background">#F2F2F7</color>
    <color name="course_ended">#9E9E9E</color>
    <color name="free_time_color">#81C784</color>
    <color name="on_surface">#000000</color>
    <color name="person_a_color">#FFB74D</color>
    <color name="person_b_color">#4789FE</color>
    <color name="primary">#007AFF</color>
    <color name="primary_variant">#1A5CB0</color>
    <color name="secondary">#8E8E93</color>
    <color name="surface">#FFFFFF</color>
    <string name="app_name">双人课程表</string>
    <string name="no_class">无课</string>
    <string name="no_courses">暂无课程</string>
    <string name="no_free_time">今日无共同空闲</string>
    <string name="person_a">Ta的课表</string>
    <string name="person_b">我的课表</string>
    <string name="preview_course_name">高等数学</string>
    <string name="preview_remaining_time">剩余 25 分钟</string>
    <string name="widget_description">显示今日课程安排</string>
    <string name="widget_free_time_description">显示两人共同的空闲时间段</string>
    <string name="widget_free_time_name">共同空闲时间</string>
    <string name="widget_my_courses_description">显示我的今日课程列表</string>
    <string name="widget_my_courses_name">我的今日课程</string>
    <string name="widget_name">今日课程</string>
    <string name="widget_ta_courses_description">显示Ta的今日课程列表</string>
    <string name="widget_ta_courses_name">Ta的今日课程</string>
    <style name="CalendarViewStyle" parent="android:Widget.Material.Light.CalendarView">
        <item name="android:selectedWeekBackgroundColor">@color/primary</item>
        <item name="android:focusedMonthDateColor">@color/on_surface</item>
        <item name="android:unfocusedMonthDateColor">@color/on_surface</item>
    </style>
    <style name="DatePickerStyle" parent="android:Widget.Material.Light.DatePicker">
        <item name="android:headerBackground">@color/primary</item>
        <item name="android:calendarViewStyle">@style/CalendarViewStyle</item>
    </style>
    <style name="Theme.AppWidget.AppWidgetContainerParent" parent="@android:style/Theme.DeviceDefault">
        <item name="android:colorAccent">@color/primary</item>
    </style>
    <style name="Theme.DuoSchedule" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">@color/primary</item>
        <item name="android:colorPrimaryDark">@color/primary_variant</item>
        <item name="android:colorAccent">@color/primary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/background</item>
        
        <item name="android:datePickerStyle">@style/DatePickerStyle</item>
        <item name="android:timePickerStyle">@style/TimePickerStyle</item>
    </style>
    <style name="Theme.DuoSchedule.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">200</item>
        <item name="postSplashScreenTheme">@style/Theme.DuoSchedule</item>
    </style>
    <style name="TimePickerStyle" parent="android:Widget.Material.Light.TimePicker">
        <item name="android:headerBackground">@color/primary</item>
    </style>
    <style name="Widget.AppWidget.AppWidget.Container" parent="@android:style/Widget">
        <item name="android:background">@drawable/widget_system_background</item>
        <item name="android:colorAccent">@color/primary</item>
    </style>
</resources>
/* Button - Liquid Glass - Text */

/* Auto layout */
display: flex;
flex-direction: row;
justify-content: center;
align-items: center;
padding: 6px 20px;
gap: 4px;
isolation: isolate;

width: 139px;
height: 48px;

border-radius: 1000px;

/* Inside auto layout */
flex: none;
order: 2;
flex-grow: 0;


/* BG */

position: absolute;
left: 0px;
right: 0px;
top: 0px;
bottom: 0px;


/* Inside auto layout */
flex: none;
order: 0;
flex-grow: 0;
z-index: 0;


/* Fill + Shadow */

position: absolute;
left: 0px;
right: 0px;
top: 0px;
bottom: 0px;

background: linear-gradient(0deg, #F7F7F7, #F7F7F7), linear-gradient(0deg, #DDDDDD, #DDDDDD), rgba(255, 255, 255, 0.65);
background-blend-mode: darken, color-burn, normal;
box-shadow: 0px 8px 40px rgba(0, 0, 0, 0.12);
border-radius: 296px;


/* Glass Effect */

position: absolute;
left: 0px;
right: 0px;
top: 0px;
bottom: 0px;

background: rgba(0, 0, 0, 0.004);
border-radius: 296px;


/* Text */

/* Auto layout */
display: flex;
flex-direction: row;
justify-content: center;
align-items: center;
padding: 0px;

width: 99px;
height: 36px;

border-radius: 100px;

/* Inside auto layout */
flex: none;
order: 1;
flex-grow: 0;
z-index: 1;


/* Symbol */

width: 99px;
height: 20px;

font-family: 'SF Pro';
font-style: normal;
font-weight: 510;
font-size: 17px;
line-height: 20px;
display: flex;
align-items: center;
text-align: center;
font-feature-settings: 'ss16' on;

color: #1A1A1A;

mix-blend-mode: plus-darker;

/* Inside auto layout */
flex: none;
order: 0;
flex-grow: 0;


/* Grabber */

position: absolute;
width: 36px;
height: 5px;
left: calc(50% - 36px/2 - 1px);
top: 5px;

background: rgba(60, 60, 67, 0.3);
border-radius: 2.5px;

/* Inside auto layout */
flex: none;
order: 8;
flex-grow: 0;
z-index: 8;


/* Home Indicator */

position: absolute;
visibility: hidden;
height: 34px;
left: 0px;
right: 0px;
bottom: 0px;



/* Status bar */


flex: none;
order: 0;
flex-grow: 0;


/* Levels */

/* Auto layout */
display: flex;
flex-direction: row;
justify-content: center;
align-items: center;
padding: 1px 1px 0px 0px;
gap: 7px;

width: 100px;
height: 22px;


/* Inside auto layout */
flex: none;
order: 1;
flex-grow: 1;


/* Cellular Connection */

